{
  "name": "luxe-adobes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "images:build": "node scripts/generate-responsive-derivatives.mjs",
    "images:heroes": "node scripts/compress-heroes.mjs && npm run images:build",
    "images:compress": "node scripts/compress-images.mjs && node scripts/finalize-compression.mjs && node scripts/apply-compression-map.mjs && node scripts/compress-jpeg-inplace.mjs && npm run images:build",
    "seo:sitemap": "node scripts/generate-sitemap.mjs",
    "seo:favicons": "node scripts/generate-favicons.mjs",
    "seo:og-image": "node scripts/generate-og-image.mjs",
    "seo:llms": "node scripts/generate-llms.mjs",
    "prebuild": "npm run seo:favicons && npm run seo:og-image && npm run seo:llms && npm run images:build && npm run seo:sitemap",
    "build": "vite build && node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@gsap/react": "^2.1.2",
    "framer-motion": "^10.16.4",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.31",
    "puppeteer": "^25.0.4",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0"
  }
}
